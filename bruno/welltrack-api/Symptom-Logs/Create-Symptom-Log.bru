meta {
  name: Create Symptom Log
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/symptom-logs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "symptom_id": "uuid-of-symptom",
    "severity": 7,
    "notes": "Started after lunch",
    "logged_at": "2025-01-15T10:00:00.000Z"
  }
}
