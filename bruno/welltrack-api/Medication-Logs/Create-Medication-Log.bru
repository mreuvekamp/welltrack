meta {
  name: Create Medication Log
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/medication-logs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "medication_id": "uuid-of-medication",
    "taken": true,
    "taken_at": "2025-01-15T10:00:00.000Z",
    "notes": "Took with breakfast"
  }
}
